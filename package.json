{
  "name": "network-operations-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.18.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "contracts:generate": "node scripts/contracts-generate.mjs",
    "contracts:check": "node scripts/contracts-check.mjs",
    "test:contract": "node scripts/contracts-test.mjs",
    "test:contract:docker": "node scripts/contracts-docker-test.mjs",
    "format:check": "prettier --check --ignore-unknown package.json tsconfig.json eslint.config.mjs scripts .github README.md",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "node --test scripts/workspace-baseline.test.ts",
    "test:recovery": "npm run build --workspace @nop/platform && node tests/recovery/runtime/run.mjs",
    "build": "tsc --project tsconfig.json",
    "verify": "npm run contracts:check && npm run test:contract && npm run format:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
