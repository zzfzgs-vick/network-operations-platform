{
  "name": "@nop/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node dist/migrate.js up",
    "db:status": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node dist/migrate.js status",
    "db:verify": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node dist/migrate.js verify",
    "identity:bootstrap-admin": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node dist/modules/identity-access/bootstrap-admin.js",
    "start:api": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "build": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js",
    "test": "tsc --project tsconfig.build.json && node src/config/run-tests.mjs",
    "test:db": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node ../../scripts/db-test.mjs",
    "test:integration": "tsc --project tsconfig.build.json && node dist/database/copy-migrations.js && node ../../tests/integration/config/run.mjs",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nop/contracts": "0.0.0",
    "argon2": "0.44.0",
    "otpauth": "9.5.1",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  }
}
