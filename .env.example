# Local development only. Never reuse these values in production.
# Production supplies every Secret through the matching *_FILE variable.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=network_operations
DATABASE_USER=nop
DATABASE_PASSWORD=change-me-local-only
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_QUERY_TIMEOUT_MS=10000
COLLECTOR_SERVICE_TOKEN=t008-local-development-only-collector-token
VMALERT_SERVICE_TOKEN=t008-local-development-only-vmalert-token
VICTORIAMETRICS_PORT=8428
VMALERT_PORT=8880
VICTORIAMETRICS_URL=http://127.0.0.1:8428
VMALERT_URL=http://127.0.0.1:8880
PLATFORM_HEALTH_TIMEOUT_MS=2000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_HEARTBEAT_STALE_AFTER_MS=15000
WORKER_INSTANCE_ID=platform-worker-local
API_DRAIN_TIMEOUT_MS=5000
API_SHUTDOWN_TIMEOUT_MS=15000
WORKER_SHUTDOWN_TIMEOUT_MS=15000
COLLECTOR_HEALTH_LISTEN_ADDRESS=127.0.0.1:9090
COLLECTOR_HEALTH_SHUTDOWN_TIMEOUT_MS=2000
WEB_PORT=4173
API_PORT=3000
WEB_ORIGIN=http://127.0.0.1:3000
SESSION_REVALIDATION_INTERVAL_MS=5000
LOG_LEVEL=info
# Opaque Web Session policy (milliseconds; local development example)
SESSION_PRE_AUTH_TIMEOUT_MS=300000
SESSION_IDLE_TIMEOUT_MS=1800000
SESSION_ABSOLUTE_TIMEOUT_MS=43200000
# TOTP application encryption (local development only; production uses *_FILE)
TOTP_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TOTP_ENCRYPTION_KEY_VERSION=v1
TOTP_ENROLLMENT_TIMEOUT_MS=300000
TOTP_CHALLENGE_MAX_ATTEMPTS=5
TOTP_THROTTLE_DURATION_MS=30000
